{
  "name": "@mc-host/host-agent",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "pkg": "npx -y pkg@5.8.1 . --targets node18-win-x64 --output bin/host-agent-x86_64-pc-windows-msvc.exe",
    "pkg:macos-arm64": "npx -y pkg@5.8.1 . --targets node18-macos-arm64 --output bin/host-agent-aarch64-apple-darwin",
    "pkg:macos-x64": "npx -y pkg@5.8.1 . --targets node18-macos-x64 --output bin/host-agent-x86_64-apple-darwin",
    "pkg:macos": "npm run pkg:macos-arm64 && npm run pkg:macos-x64",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/test"
    ],
    "moduleNameMapper": {
      "^@mc-host/shared-types$": "<rootDir>/../../packages/shared-types/src"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "archiver": "^6.0.1",
    "axios": "^1.6.7",
    "better-sqlite3": "^9.4.3",
    "express": "^4.18.2",
    "extract-zip": "^2.0.1",
    "node-fetch": "^2.7.0",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/better-sqlite3": "^7.6.9",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/node-fetch": "^2.6.11",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
